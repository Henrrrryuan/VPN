FLASK_ENV=development
SECRET_KEY=change-me-to-a-strong-random-string
JWT_EXPIRES_HOURS=24
DATABASE_URL=sqlite:///app.db

# x-ui panel base URL, e.g. http://your-server:2053
XUI_BASE_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=admin

# inbound ID from 3X-UI
XUI_INBOUND_ID=1

# Max distinct source IPs per client UUID at once (3X-UI limitIp). 0 = unlimited.
XUI_CLIENT_LIMIT_IP=2

# If panel needs HTTPS with self-signed cert, set false
XUI_VERIFY_SSL=true

# Optional: force host/ip in generated VLESS link.
# Example: 139.180.136.98
XUI_PUBLIC_HOST=

# Optional bootstrap nodes (JSON array). Only used when nodes table is empty.
# Example:
# NODES_JSON=[{"name":"SG-1","region":"SG","base_url":"http://1.2.3.4:2053","username":"admin","password":"xxx","inbound_id":1,"verify_ssl":true,"public_host":"1.2.3.4"},{"name":"JP-1","region":"JP","base_url":"http://5.6.7.8:2053","username":"admin","password":"yyy","inbound_id":1,"verify_ssl":true,"public_host":"5.6.7.8"}]
NODES_JSON=
