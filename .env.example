FLASK_ENV=development
SECRET_KEY=change-me-to-a-strong-random-string
JWT_EXPIRES_HOURS=24
DATABASE_URL=sqlite:///app.db

# 可选：落地页若在别的静态服务器预览，把链接指到本 Flask 根地址（无尾斜杠），例如 http://127.0.0.1:5001
# 正常整站由 Flask 提供时可留空。不要用 Live Server 直接打开 templates/*.html（Jinja 未渲染会坏）。
AUTH_PAGE_BASE_URL=

# 3X-UI 面板根地址（与浏览器地址栏一致，不要带 /panel/inbounds）。
# 方式 A：写完整根，例如 http://139.180.136.98:4647/LIpz75bRbfQtHWunT5（含「面板设置」里的 Web 基础路径）。
# 方式 B：只写 http://ip:端口，另设下方 XUI_WEB_BASE_PATH=/LIpz75bRbfQtHWunT5。
# 本应用会请求 base_url/login、base_url/panel/api/inbounds/list 等。
XUI_BASE_URL=http://127.0.0.1:2053
# 若 XUI_BASE_URL 未含 Web 基础路径，在此填写（与 3X-UI 面板设置一致，以 / 开头）。
XUI_WEB_BASE_PATH=
XUI_USERNAME=admin
XUI_PASSWORD=admin

# 来自 3X-UI 的 inbound ID
XUI_INBOUND_ID=1

# 3X-UI 创建用户时写入的 limitIp（面板「IP 限制」），非本系统「同时在线」展示（该功能已移除）。
XUI_CLIENT_LIMIT_IP=2

# 若面板使用 HTTPS 且为自签证书，设置为 false。
XUI_VERIFY_SSL=true

# 可选：强制生成的 VLESS 链接使用指定的域名/Host。
# 示例：139.180.136.98
XUI_PUBLIC_HOST=

# 可选：预置节点列表（JSON 数组）。当 nodes 表为空时才会使用。
# 示例：
# NODES_JSON=[{"name":"SG-1","region":"SG","base_url":"http://1.2.3.4:2053","username":"admin","password":"xxx","inbound_id":1,"verify_ssl":true,"public_host":"1.2.3.4"},{"name":"JP-1","region":"JP","base_url":"http://5.6.7.8:2053","username":"admin","password":"yyy","inbound_id":1,"verify_ssl":true,"public_host":"5.6.7.8"}]
NODES_JSON=

# 管理员：浏览器打开 /admin 与调用 /api/admin/* 时请求头 X-Admin-Token 须与此一致。留空则禁用管理员接口。
ADMIN_TOKEN=
