FLASK_ENV=development
SECRET_KEY=change-me-to-a-strong-random-string
JWT_EXPIRES_HOURS=24
DATABASE_URL=sqlite:///app.db

# 3X-UI 面板基础地址，例如 http://your-server:2053
XUI_BASE_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=admin

# 来自 3X-UI 的 inbound ID
XUI_INBOUND_ID=1

# 每个客户端 UUID 同一时间允许的不同来源公网 IP 数（3X-UI 的 limitIp）。0 = 不限制。
XUI_CLIENT_LIMIT_IP=2

# 若面板使用 HTTPS 且为自签证书，设置为 false。
XUI_VERIFY_SSL=true

# 可选：强制生成的 VLESS 链接使用指定的域名/Host。
# 示例：139.180.136.98
XUI_PUBLIC_HOST=

# 可选：预置节点列表（JSON 数组）。当 nodes 表为空时才会使用。
# 示例：
# NODES_JSON=[{"name":"SG-1","region":"SG","base_url":"http://1.2.3.4:2053","username":"admin","password":"xxx","inbound_id":1,"verify_ssl":true,"public_host":"1.2.3.4"},{"name":"JP-1","region":"JP","base_url":"http://5.6.7.8:2053","username":"admin","password":"yyy","inbound_id":1,"verify_ssl":true,"public_host":"5.6.7.8"}]
NODES_JSON=

# 节点侧上报在线事件的密钥（请求头：X-Ingest-Key）
ONLINE_INGEST_KEY=change-online-ingest-key

# 在线统计窗口（秒）：统计最近 N 秒内出现过的不同来源 IP 数
ONLINE_STATS_WINDOW_SEC=30

# 同一来源 IP 在统计窗口内至少出现 N 条事件，才计为在线。
ONLINE_MIN_EVENTS_PER_IP=2

# 仅当超过该秒数都没有收到在线上报时，才回退到 x-ui 的 lastOnline 估算。
ONLINE_FALLBACK_GRACE_SEC=120

# 是否启用 x-ui lastOnline 回退估算。精准展示建议关闭（false）。
ONLINE_ENABLE_XUI_FALLBACK=false
