[Unit]
Description=VPN SaaS Flask Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/vpn-saas
Environment="HOST=0.0.0.0"
Environment="PORT=5001"
ExecStart=/opt/vpn-saas/.venv/bin/python /opt/vpn-saas/run.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
